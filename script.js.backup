   482|                <button class="copy-btn" onclick="event.stopPropagation();copyCode('${escHtml(code.code)}', this)"${code.color ? ` style="background:${code.color}"` : ''}>
   483|                    <i data-lucide="copy"></i> Copy
   484|                </button>
   485|            </div>
   486|            ${code.url ? `<a href="${escHtml(code.url)}" target="_blank" rel="noopener noreferrer" class="code-link" onclick="event.stopPropagation();trackClick('codes','${code.id}')">
   487|                <i data-lucide="external-link"></i> Siirry kauppaan
   488|            </a>` : ''}
   489|            <div class="code-clicks">${(code.clicks||0)} clicks</div>
