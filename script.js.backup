   555|function filterCodes() {
   556|    const searchVal = document.getElementById('codesSearch')?.value.toLowerCase() || '';
   557|    const cards = document.querySelectorAll('.code-card');
   558|    cards.forEach(card => {
   559|        const tags = JSON.parse(card.dataset.tags || '[]');
   560|        const text = card.textContent.toLowerCase();
   561|        const matchesSearch = !searchVal || text.includes(searchVal);
   562|        const matchesFilters = activeCodeFilters.size === 0 ||
   563|            Array.from(activeCodeFilters).every(f => tags.includes(f));
   564|        card.style.display = (matchesSearch && matchesFilters) ? '' : 'none';
   565|    });
