   581|// ─── POPUP (expanded detail, no page leave) ──────────────────────────────
   582|function showItemPopup(item, type) {
   583|    let overlay = document.getElementById('itemPopup');
   584|    if (!overlay) {
   585|        overlay = document.createElement('div');
   586|        overlay.id = 'itemPopup';
   587|        overlay.addEventListener('click', (e) => { if (e.target === overlay) { overlay.classList.remove('open'); } });
   588|        document.body.appendChild(overlay);
   589|    }
   590|    
   591|    trackClick(type + 's', item.id);
   592|    
   593|    const isAffiliate = type === 'affiliate';
   594|    const tags = normalizeTags(item.tags || item.features || []);
   595|    const tagsHtml = tags.map(t => `<span class="popup-tag">#${escHtml(t)}</span>`).join('');
   596|    const color = item.color || '';
   597|    
   598|    overlay.innerHTML = `<div class="popup-card${color ? ' has-color' : ''}" ${color ? `style="--popup-accent:${color}"` : ''}>
   599|        <button class="popup-close" onclick="document.getElementById('itemPopup').classList.remove('open')">✕</button>
   600|        ${item.image ? `<img src="${escHtml(item.image)}" class="popup-image" alt="">` : ''}
   601|        ${item.isHot || (item.clicks > 0) ? '<div class="popup-hot">🔥 HOT</div>' : ''}
   602|        <h2 class="popup-title">${escHtml(item.title || item.store)}</h2>
   603|        ${item.description ? `<p class="popup-desc">${escHtml(item.description)}</p>` : ''}
   604|        ${item.discount ? `<div class="popup-discount"${color ? ` style="background:${color}"` : ''}>${escHtml(item.discount)} OFF</div>` : ''}
   605|        ${item.price ? `<div class="popup-price">${escHtml(item.price)}</div>` : ''}
   606|        ${tags.length ? `<div class="popup-tags">${tagsHtml}</div>` : ''}
   607|        ${item.code ? `<div class="popup-code-box">
   608|            <span class="popup-code-value"${color ? ` style="color:${color}"` : ''}>${escHtml(item.code)}</span>
   609|            <button class="copy-btn popup-copy"${color ? ` style="background:${color}"` : ''} onclick="copyCode('${escHtml(item.code)}', this)">
   610|                <i data-lucide="copy"></i> Copy
   611|            </button>
   612|        </div>` : ''}
   613|        ${item.url ? `<a href="${escHtml(item.url)}" target="_blank" rel="noopener noreferrer" class="popup-cta"${color ? ` style="background:${color}"` : ''}>
   614|            ${isAffiliate ? '<i data-lucide="shopping-cart"></i> Osta nyt' : '<i data-lucide="external-link"></i> Siirry kauppaan'}
   615|        </a>` : ''}
   616|        ${item.youtubeId ? `<button class="popup-yt" onclick="showYtEmbed('${escHtml(item.youtubeId)}')"><i data-lucide="play"></i> Katso video</button>` : ''}
   617|        <div class="popup-clicks">${(item.clicks||0)} clicks</div>
   618|    </div>`;
   619|    overlay.classList.add('open');
   620|    lucide.createIcons();
   621|}
