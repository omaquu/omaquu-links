   879|// ─── UTILS ────────────────────────────────────────────────────────────────
   880|function escHtml(s) {
   881|    if (!s) return '';
   882|    return String(s).replace(/&/g,'&').replace(/</g,'<').replace(/>/g,'>').replace(/"/g,'"');
   883|}
