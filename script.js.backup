     1|// ============================================
     2|// omaquu Link Site - Main Script v3
     3|// Features: Links + Codes + Shop + Kick Live
     4|//   + Quick Links + Per-link colors + Stream Always
     5|//   + Background animations (particles/matrix/stars)
     6|//   + Tag counts in shop
     7|// ============================================
     8|
     9|// Icon mappings
    10|const ICONS = {
    11|    youtube: 'youtube', twitch: 'tv', kick: 'zap', tiktok: 'music',
    12|    x: 'x', instagram: 'instagram', snapchat: 'circle', discord: 'message-circle',
    13|    kofi: 'coffee', email: 'mail', link: 'external-link'
    14|};
    15|
    16|const CATEGORY_LABELS = {
    17|    social: 'Sosiaalinen media', stream: 'Striimi',
    18|    support: 'Tuki', contact: 'Yhteys'
    19|};
    20|
    21|let siteData = {
    22|    profile: { username: '@omaquu', displayName: 'omaquu', bio: '', avatar: '', quickLinks: [] },
    23|    links: [], codes: [], affiliates: [], streamAlwaysVisible: false
    24|};
    25|
    26|let currentTheme = {};
    27|let activeFilters = new Set();
    28|let activeCodeFilters = new Set();
    29|let codesLayout = 'list';
    30|let shopLayout = 'list';
    31|let animFrame = null;
    32|
    33|// ─── LOAD DATA ────────────────────────────────────────────────────────────
    34|async function loadData() {
    35|    try {
    36|        // Load theme first
    37|        try {
    38|            const themeRes = await fetch('theme.json');
    39|            if (themeRes.ok) {
    40|                currentTheme = await themeRes.json();
    41|                applyTheme(currentTheme);
    42|            }
    43|        } catch(e) {}
    44|
    45|        // Load data
    46|        const response = await fetch('data.json');
    47|        siteData = await response.json();
    48|        renderAll();
    49|        checkStreamLive();
    50|    } catch (err) {
    51|        console.error('Failed to load data:', err);
    52|        siteData = getFallbackData();
    53|        renderAll();
    54|    }
    55|}
    56|
    57|// ─── THEME ────────────────────────────────────────────────────────────────
    58|function applyTheme(theme) {
    59|    const root = document.documentElement;
    60|    const varMap = {
    61|        accent: '--accent', accentGlow: '--accent-glow',
    62|        bgPrimary: '--bg-primary', bgSecondary: '--bg-secondary',
    63|        bgCard: '--bg-card', bgCardHover: '--bg-card-hover',
    64|        textPrimary: '--text-primary', textSecondary: '--text-secondary',
    65|        textMuted: '--text-muted', border: '--border',
    66|        live: '--live', success: '--success'
    67|    };
    68|    Object.entries(varMap).forEach(([key, cssVar]) => {
    69|        if (theme[key]) root.style.setProperty(cssVar, theme[key]);
    70|    });
    71|
    72|    // Background image
    73|    const bgOverlay = document.getElementById('bgImageOverlay');
    74|    if (bgOverlay) {
    75|        if (theme.bgImage) {
    76|            bgOverlay.style.backgroundImage = `url(${theme.bgImage})`;
    77|            bgOverlay.style.display = 'block';
    78|        } else {
    79|            bgOverlay.style.display = 'none';
    80|        }
    81|    }
    82|
    83|    // Background animation
    84|    if (theme.bgAnimation) {
    85|        startBgAnimation(theme.bgAnimation, theme.animationColor || theme.accent || '#ff6b35');
    86|    } else if (animFrame) {
    87|        cancelAnimationFrame(animFrame);
    88|        animFrame = null;
    89|        const canvas = document.getElementById('bgCanvas');
    90|        if (canvas) { const ctx = canvas.getContext('2d'); ctx.clearRect(0, 0, canvas.width, canvas.height); }
    91|    }
    92|}
    93|
    94|// ─── BACKGROUND ANIMATIONS ─────────────────────────────────────────────────
    95|function startBgAnimation(type, color) {
    96|    const canvas = document.getElementById('bgCanvas');
    97|    if (!canvas) return;
    98|    const ctx = canvas.getContext('2d');
    99|    
   100|    function resize() {
   101|        canvas.width = window.innerWidth;
   102|        canvas.height = window.innerHeight;
   103|    }
   104|    resize();
   105|    window.addEventListener('resize', resize);
   106|
   107|    if (animFrame) cancelAnimationFrame(animFrame);
   108|
   109|    const hex = color.replace('#', '');
   110|    const r = parseInt(hex.substring(0, 2), 16);
   111|    const g = parseInt(hex.substring(2, 4), 16);
   112|    const b = parseInt(hex.substring(4, 6), 16);
   113|
   114|    if (type === 'particles') {
   115|        // Floating particles
   116|        const particles = Array.from({length: 60}, () => ({
   117|            x: Math.random() * canvas.width,
   118|            y: Math.random() * canvas.height,
   119|            vx: (Math.random() - 0.5) * 0.5,
   120|            vy: (Math.random() - 0.5) * 0.5,
   121|            size: Math.random() * 3 + 1,
   122|            alpha: Math.random() * 0.5 + 0.1
   123|        }));
   124|
   125|        function drawParticles() {
   126|            ctx.clearRect(0, 0, canvas.width, canvas.height);
   127|            particles.forEach(p => {
   128|                ctx.beginPath();
   129|                ctx.arc(p.x, p.y, Math.max(0.5, p.size), 0, Math.PI * 2);
   130|                ctx.fillStyle = `rgba(${r},${g},${b},${p.alpha})`;
   131|                ctx.fill();
   132|                p.x += p.vx;
   133|                p.y += p.vy;
   134|                if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
   135|                if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
   136|            });
   137|            // Draw lines between close particles
   138|            for (let i = 0; i < particles.length; i++) {
   139|                for (let j = i + 1; j < particles.length; j++) {
   140|                    const dx = particles[i].x - particles[j].x;
   141|                    const dy = particles[i].y - particles[j].y;
   142|                    const dist = Math.sqrt(dx * dx + dy * dy);
   143|                    if (dist < 120) {
   144|                        ctx.beginPath();
   145|                        ctx.moveTo(particles[i].x, particles[i].y);
   146|                        ctx.lineTo(particles[j].x, particles[j].y);
   147|                        ctx.strokeStyle = `rgba(${r},${g},${b},${0.1 * (1 - dist / 120)})`;
   148|                        ctx.stroke();
   149|                    }
   150|                }
   151|            }
   152|            animFrame = requestAnimationFrame(drawParticles);
   153|        }
   154|        drawParticles();
   155|
   156|    } else if (type === 'matrix') {
   157|        // Matrix rain
   158|        const fontSize = 14;
   159|        const cols = Math.floor(canvas.width / fontSize);
   160|        const drops = Array(cols).fill(1);
   161|        const chars = 'OMAQUU0123456789ABCDEF@#$%&';
   162|
   163|        function drawMatrix() {
   164|            ctx.fillStyle = 'rgba(10,10,15,0.05)';
   165|            ctx.fillRect(0, 0, canvas.width, canvas.height);
   166|            ctx.fillStyle = `rgba(${r},${g},${b},0.8)`;
   167|            ctx.font = fontSize + 'px monospace';
   168|
   169|            drops.forEach((y, i) => {
   170|                const text = chars[Math.floor(Math.random() * chars.length)];
   171|                ctx.fillText(text, i * fontSize, y * fontSize);
   172|                if (y * fontSize > canvas.height && Math.random() > 0.975) {
   173|                    drops[i] = 0;
   174|                }
   175|                drops[i]++;
   176|            });
   177|            animFrame = requestAnimationFrame(drawMatrix);
   178|        }
   179|        drawMatrix();
   180|
   181|    } else if (type === 'stars') {
   182|        // Twinkling stars
   183|        const stars = Array.from({length: 150}, () => ({
   184|            x: Math.random() * canvas.width,
   185|            y: Math.random() * canvas.height,
   186|            size: Math.random() * 2 + 0.5,
   187|            speed: Math.random() * 0.02 + 0.005,
   188|            phase: Math.random() * Math.PI * 2
   189|        }));
   190|        let time = 0;
   191|
   192|        function drawStars() {
   193|            ctx.clearRect(0, 0, canvas.width, canvas.height);
   194|            time += 0.016;
   195|            stars.forEach(s => {
   196|                const alpha = 0.3 + 0.5 * Math.sin(time * s.speed * 60 + s.phase);
   197|                ctx.beginPath();
   198|                ctx.arc(s.x, s.y, Math.max(0.3, s.size), 0, Math.PI * 2);
   199|                ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
   200|                ctx.fill();
   201|            });
   202|            animFrame = requestAnimationFrame(drawStars);
   203|        }
   204|        drawStars();
   205|
   206|    } else if (type === 'grid') {
   207|        // Neon grid (Tron-like)
   208|        let offset = 0;
   209|        const spacing = 50;
   210|        function drawGrid() {
   211|            ctx.clearRect(0, 0, canvas.width, canvas.height);
   212|            offset = (offset + 0.3) % spacing;
   213|            ctx.strokeStyle = `rgba(${r},${g},${b},0.12)`;
   214|            ctx.lineWidth = 1;
   215|            // Vertical lines
   216|            for (let x = -offset; x < canvas.width + spacing; x += spacing) {
   217|                ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke();
   218|            }
   219|            // Horizontal lines moving down
   220|            for (let y = -offset; y < canvas.height + spacing; y += spacing) {
   221|                ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke();
   222|            }
   223|            // Horizon glow
   224|            const grad = ctx.createLinearGradient(0, canvas.height * 0.5, 0, canvas.height);
   225|            grad.addColorStop(0, 'transparent');
   226|            grad.addColorStop(1, `rgba(${r},${g},${b},0.06)`);
   227|            ctx.fillStyle = grad;
   228|            ctx.fillRect(0, 0, canvas.width, canvas.height);
   229|            animFrame = requestAnimationFrame(drawGrid);
   230|        }
   231|        drawGrid();
   232|
   233|    } else if (type === 'fire') {
   234|        // Rising fire particles
   235|        const sparks = Array.from({length: 80}, () => ({
   236|            x: Math.random() * canvas.width, y: canvas.height + Math.random() * 100,
   237|            vx: (Math.random() - 0.5) * 1.5, vy: -(Math.random() * 2 + 0.5),
   238|            size: Math.random() * 4 + 1, life: Math.random()
   239|        }));
   240|        function drawFire() {
   241|            ctx.clearRect(0, 0, canvas.width, canvas.height);
   242|            sparks.forEach(p => {
   243|                const alpha = p.life * 0.7;
   244|                ctx.beginPath();
   245|                ctx.arc(p.x, p.y, Math.max(0.5, p.size * p.life), 0, Math.PI * 2);
   246|                // Color shifts from accent to orange/yellow as it rises
   247|                const er = Math.min(255, r + (255 - r) * (1 - p.life));
   248|                const eg = Math.min(200, g + (180 - g) * (1 - p.life));
   249|                ctx.fillStyle = `rgba(${er},${eg},${b},${alpha})`;
   250|                ctx.fill();
   251|                p.x += p.vx; p.y += p.vy; p.life -= 0.005;
   252|                if (p.life <= 0) { p.x = Math.random() * canvas.width; p.y = canvas.height + 10; p.life = 1; }
   253|            });
   254|            animFrame = requestAnimationFrame(drawFire);
   255|        }
   256|        drawFire();
   257|
   258|    } else if (type === 'bubbles') {
   259|        // Rising bubbles
   260|        const bubbles = Array.from({length: 50}, () => ({
   261|            x: Math.random() * canvas.width, y: canvas.height + Math.random() * 200,
   262|            size: Math.random() * 8 + 2, speed: Math.random() * 0.8 + 0.3,
   263|            wobble: Math.random() * Math.PI * 2
   264|        }));
   265|        let t = 0;
   266|        function drawBubbles() {
   267|            ctx.clearRect(0, 0, canvas.width, canvas.height);
   268|            t += 0.01;
   269|            bubbles.forEach(b => {
   270|                const bx = b.x + Math.sin(t + b.wobble) * 20;
   271|                ctx.beginPath();
   272|                ctx.arc(bx, b.y, Math.max(1, b.size), 0, Math.PI * 2);
   273|                ctx.strokeStyle = `rgba(${r},${g},${b},0.3)`;
   274|                ctx.lineWidth = 1;
   275|                ctx.stroke();
   276|                // Highlight
   277|                ctx.beginPath();
   278|                ctx.arc(bx - b.size * 0.25, b.y - b.size * 0.25, Math.max(0.5, b.size * 0.2), 0, Math.PI * 2);
   279|                ctx.fillStyle = `rgba(${r},${g},${b},0.15)`;
   280|                ctx.fill();
   281|                b.y -= b.speed;
   282|                if (b.y < -b.size * 2) { b.y = canvas.height + b.size; b.x = Math.random() * canvas.width; }
   283|            });
   284|            animFrame = requestAnimationFrame(drawBubbles);
   285|        }
   286|        drawBubbles();
   287|
   288|    } else if (type === 'aurora') {
   289|        // Northern lights waves
   290|        let t = 0;
   291|        function drawAurora() {
   292|            ctx.clearRect(0, 0, canvas.width, canvas.height);
   293|            t += 0.008;
   294|            for (let band = 0; band < 4; band++) {
   295|                ctx.beginPath();
   296|                const yBase = canvas.height * (0.2 + band * 0.12);
   297|                ctx.moveTo(0, yBase);
   298|                for (let x = 0; x <= canvas.width; x += 4) {
   299|                    const y = yBase + Math.sin(x * 0.005 + t * 2 + band) * 30
   300|                                    + Math.sin(x * 0.01 + t * 3 + band * 2) * 15;
   301|                    ctx.lineTo(x, y);
   302|                }
   303|                ctx.lineTo(canvas.width, canvas.height);
   304|                ctx.lineTo(0, canvas.height);
   305|                ctx.closePath();
   306|                const alpha = 0.03 + band * 0.01;
   307|                // Alternate between accent color and complementary
   308|                const cr = band % 2 === 0 ? r : Math.min(255, r + 80);
   309|                const cg = band % 2 === 0 ? g : Math.max(0, g - 60);
   310|                const cb = band % 2 === 0 ? b : Math.min(255, b + 100);
   311|                ctx.fillStyle = `rgba(${cr},${cg},${cb},${alpha})`;
   312|                ctx.fill();
   313|            }
   314|            animFrame = requestAnimationFrame(drawAurora);
   315|        }
   316|        drawAurora();
   317|
   318|    } else if (type === 'galaxy') {
   319|        // Swirling galaxy dots
   320|        const dots = Array.from({length: 200}, () => ({
   321|            angle: Math.random() * Math.PI * 2,
   322|            dist: Math.random() * Math.min(canvas.width, canvas.height) * 0.4 + 20,
   323|            speed: (Math.random() * 0.002 + 0.0005) * (Math.random() > 0.5 ? 1 : -1),
   324|            size: Math.random() * 2 + 0.5,
   325|            alpha: Math.random() * 0.5 + 0.1
   326|        }));
   327|        const cx = canvas.width / 2, cy = canvas.height / 2;
   328|        function drawGalaxy() {
   329|            ctx.clearRect(0, 0, canvas.width, canvas.height);
   330|            dots.forEach(d => {
   331|                const x = cx + Math.cos(d.angle) * d.dist;
   332|                const y = cy + Math.sin(d.angle) * d.dist * 0.6;
   333|                ctx.beginPath();
   334|                ctx.arc(x, y, Math.max(0.3, d.size), 0, Math.PI * 2);
   335|                ctx.fillStyle = `rgba(${r},${g},${b},${d.alpha})`;
   336|                ctx.fill();
   337|                d.angle += d.speed;
   338|            });
   339|            // Center glow
   340|            const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, 60);
   341|            grad.addColorStop(0, `rgba(${r},${g},${b},0.08)`);
   342|            grad.addColorStop(1, 'transparent');
   343|            ctx.fillStyle = grad;
   344|            ctx.fillRect(cx - 60, cy - 60, 120, 120);
   345|            animFrame = requestAnimationFrame(drawGalaxy);
   346|        }
   347|        drawGalaxy();
   348|    }
   349|}
   350|
   351|// ─── EMBED AUTO-DETECT ────────────────────────────────────────────────────
   352|function detectEmbedFromUrl(url) {
   353|    if (!url) return null;
   354|    url = url.trim();
   355|    const kickMatch = url.match(/kick\.com\/([a-zA-Z0-9_]+)/);
   356|    if (kickMatch) return { type: 'kick', username: kickMatch[1], embedUrl: `https://player.kick.com/${kickMatch[1]}` };
   357|    const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/live\/)([a-zA-Z0-9_-]+)/);
   358|    if (ytMatch) return { type: 'youtube', videoId: ytMatch[1], embedUrl: `https://www.youtube.com/embed/${ytMatch[1]}` };
   359|    const twitchMatch = url.match(/twitch\.tv\/([a-zA-Z0-9_]+)/);
   360|    if (twitchMatch) return { type: 'twitch', username: twitchMatch[1], embedUrl: `https://player.twitch.tv/?channel=${twitchMatch[1]}&parent=${location.hostname}` };
   361|    const tiktokMatch = url.match(/tiktok\.com\/@[^\/]+\/video\/(\d+)/);
   362|    if (tiktokMatch) return { type: 'tiktok', videoId: tiktokMatch[1], embedUrl: `https://www.tiktok.com/embed/v2/${tiktokMatch[1]}` };
   363|    return null;
   364|}
   365|
   366|// ─── RENDER ALL ───────────────────────────────────────────────────────────
   367|function renderAll() {
   368|    renderProfile();
   369|    renderQuickLinks();
   370|    renderLinks();
   371|    renderCodes();
   372|    renderCodeFilterTags();
   373|    renderAffiliates();
   374|    renderFilterTags();
   375|    lucide.createIcons();
   376|}
   377|
   378|// ─── PROFILE ──────────────────────────────────────────────────────────────
   379|function renderProfile() {
   380|    const { profile } = siteData;
   381|    document.getElementById('displayName').textContent = profile.displayName;
   382|    document.getElementById('bio').textContent = profile.bio;
   383|    
   384|    const avatar = document.getElementById('avatar');
   385|    const placeholder = document.getElementById('avatarPlaceholder');
   386|    if (profile.avatar) {
   387|        avatar.src = profile.avatar;
   388|        avatar.style.display = 'block';
   389|        placeholder.style.display = 'none';
   390|    } else {
   391|        avatar.style.display = 'none';
   392|        placeholder.style.display = 'flex';
   393|        placeholder.textContent = (profile.username?.charAt(1) || 'O').toUpperCase();
   394|    }
   395|}
   396|
   397|// ─── QUICK LINKS ──────────────────────────────────────────────────────────
   398|function renderQuickLinks() {
   399|    const container = document.getElementById('quickLinks');
   400|    const links = siteData.profile?.quickLinks || [];
   401|    if (!links.length) { container.innerHTML = ''; return; }
   402|
   403|    container.innerHTML = links.map(q => `
   404|        <a href="${escHtml(q.url)}" class="quick-link" target="_blank" rel="noopener noreferrer" title="${escHtml(q.name || q.url)}">
   405|            <span class="quick-link-emoji">${q.emoji || '🔗'}</span>
   406|            ${q.name ? `<span class="quick-link-name">${escHtml(q.name)}</span>` : ''}
   407|        </a>
   408|    `).join('');
   409|}
   410|
   411|// ─── LINKS ────────────────────────────────────────────────────────────────
   412|function renderLinks() {
   413|    const container = document.getElementById('linksList');
   414|    container.innerHTML = '';
   415|    
   416|    // Sort by sort_order
   417|    const sorted = [...(siteData.links || [])].sort((a, b) => (a.sort_order || 999) - (b.sort_order || 999));
   418|
   419|    sorted.forEach(link => {
   420|        const iconName = ICONS[link.icon] || 'link';
   421|        const catLabel = CATEGORY_LABELS[link.category] || '';
   422|        const cardClass = `link-card${link.category === 'stream' ? ' stream' : link.category === 'support' ? ' support' : ''}`;
   423|        const liveBadge = link.live ? '<span class="live-badge">LIVE</span>' : '';
   424|        const catText = catLabel ? `<div class="link-category">${catLabel}</div>` : '';
   425|        
   426|        // Per-link color accent
   427|        const colorStyle = link.color ? `style="--link-accent:${link.color}"` : '';
   428|        
   429|        container.innerHTML += `
   430|            <a href="${escHtml(link.url)}" class="${cardClass}" ${colorStyle} target="_blank" rel="noopener noreferrer" onclick="trackClick('links','${link.id}')">
   431|                <div class="link-icon"${link.color ? ` style="background:${link.color}22;color:${link.color}"` : ''}>
   432|                    <i data-lucide="${iconName}"></i>
   433|                </div>
   434|                <div class="link-info">
   435|                    <div class="link-title">${escHtml(link.title)}${liveBadge}</div>
   436|                    ${catText}
   437|                </div>
   438|                <div class="link-arrow"><i data-lucide="chevron-right"></i></div>
   439|            </a>
   440|        `;
   441|    });
   442|}
   443|
   444|// ─── CODES ────────────────────────────────────────────────────────────────
   445|function renderCodes() {
   446|    const container = document.getElementById('codesList');
   447|    container.innerHTML = '';
   448|    container.className = 'codes-list layout-' + codesLayout;
   449|    
   450|    const sorted = [...(siteData.codes || [])].sort((a, b) => (a.sort_order || 999) - (b.sort_order || 999));
   451|    // HOT: top 2 by clicks
   452|    const byClicks = [...sorted].sort((a,b) => (b.clicks||0) - (a.clicks||0));
   453|    const hotIds = new Set();
   454|    for (let i = 0; i < Math.min(2, byClicks.length); i++) {
   455|        if ((byClicks[i].clicks||0) > 0) hotIds.add(byClicks[i].id);
   456|    }
   457|    
   458|    sorted.forEach(code => {
   459|        const isHot = hotIds.has(code.id);
   460|        const colorAccent = code.color ? `style="--code-accent:${code.color}"` : '';
   461|        const codeTags = normalizeTags(code.tags || code.features || '');
   462|        const tagsHtml = codeTags.map(t =>
   463|            `<span class="code-tag" onclick="event.stopPropagation();filterCodeByTag('${escHtml(t)}')">#${escHtml(t)}</span>`
   464|        ).join('');
   465|        
   466|        const card = document.createElement('div');
   467|        card.className = 'code-card compact' + (isHot ? ' hot' : '');
   468|        card.dataset.tags = JSON.stringify(codeTags);
   469|        card.dataset.id = code.id;
   470|        if (code.color) card.style.setProperty('--code-accent', code.color);
   471|        
   472|        card.innerHTML = `
   473|            ${isHot ? '<div class="hot-badge">🔥 HOT</div>' : ''}
   474|            <div class="code-header">
   475|                <span class="code-store">${escHtml(code.store || code.title)}</span>
   476|                <span class="code-discount"${code.color ? ` style="background:linear-gradient(135deg,${code.color},${code.color}cc)"` : ''}>${escHtml(code.discount || '')} OFF</span>
   477|            </div>
   478|            <div class="code-description">${escHtml(code.description || '')}</div>
   479|            ${codeTags.length ? `<div class="code-features">${tagsHtml}</div>` : ''}
   480|            <div class="code-box">
