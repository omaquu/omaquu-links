   832|// ─── YOUTUBE EMBED MODAL ─────────────────────────────────────────────────
   833|function showYtEmbed(videoId) {
   834|    let overlay = document.getElementById('ytOverlay');
   835|    if (!overlay) {
   836|        overlay = document.createElement('div');
   837|        overlay.id = 'ytOverlay';
   838|        overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;display:flex;align-items:center;justify-content:center;';
   839|        overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.remove(); });
   840|        document.body.appendChild(overlay);
   841|    }
   842|    overlay.innerHTML = `<div style="width:90%;max-width:560px;aspect-ratio:16/9;position:relative">
   843|        <iframe src="https://www.youtube.com/embed/${videoId}?autoplay=1" style="width:100%;height:100%;border:0;border-radius:12px" allowfullscreen allow="autoplay"></iframe>
   844|        <div onclick="document.getElementById('ytOverlay').remove()" style="position:absolute;top:-30px;right:0;color:#fff;font-size:1.5rem;cursor:pointer">✕</div>
   845|    </div>`;
   846|}
