   522|            tagCounts[t] = (tagCounts[t] || 0) + 1;
   523|        });
   524|    });
   525|    const allTags = Object.keys(tagCounts);
   526|    if (allTags.length === 0) { container.innerHTML = ''; return; }
   527|    allTags.sort((a, b) => tagCounts[b] - tagCounts[a]);
   528|    container.innerHTML = `<span class="filter-tag ${activeCodeFilters.size === 0 ? 'active' : ''}" onclick="clearCodeFilters()">Kaikki</span>` +
   529|        allTags.map(tag =>
   530|            `<span class="filter-tag ${activeCodeFilters.has(tag) ? 'active' : ''}" data-tag="${escHtml(tag)}" onclick="toggleCodeFilter('${escHtml(tag)}')">#${escHtml(tag)} <span class="tag-count">(${tagCounts[tag]})</span></span>`
   531|        ).join('');
   532|}
