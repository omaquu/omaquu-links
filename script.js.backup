   501|
   502|function copyCode(code, btn) {
   503|    navigator.clipboard.writeText(code).then(() => {
   504|        btn.classList.add('copied');
   505|        btn.innerHTML = '<i data-lucide="check"></i> Copied!';
   506|        lucide.createIcons();
   507|        setTimeout(() => {
   508|            btn.classList.remove('copied');
   509|            btn.innerHTML = '<i data-lucide="copy"></i> Copy';
   510|            lucide.createIcons();
   511|        }, 2000);
   512|    });
   513|}
