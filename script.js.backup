   848|// ─── TAB SWITCHING ───────────────────────────────────────────────────────
   849|function initTabs() {
   850|    const tabBtns = document.querySelectorAll('.tab-btn');
   851|    const tabContents = document.querySelectorAll('.tab-content');
   852|    
   853|    tabBtns.forEach(btn => {
   854|        btn.addEventListener('click', () => {
   855|            const tabId = btn.dataset.tab;
   856|            tabBtns.forEach(b => b.classList.remove('active'));
   857|            btn.classList.add('active');
   858|            tabContents.forEach(c => {
   859|                c.classList.remove('active');
   860|                if (c.id === tabId) c.classList.add('active');
   861|            });
   862|        });
   863|    });
   864|}
