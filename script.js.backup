   628|// ─── SHOP / AFFILIATES ────────────────────────────────────────────────────
   629|function renderAffiliates() {
   630|    const container = document.getElementById('affiliatesList');
   631|    container.innerHTML = '';
   632|    container.className = 'affiliates-grid layout-' + shopLayout;
   633|    
   634|    const sorted = [...(siteData.affiliates || [])].sort((a, b) => (a.sort_order || 999) - (b.sort_order || 999));
   635|    // HOT: top 2 by clicks
   636|    const byClicks = [...sorted].sort((a,b) => (b.clicks||0) - (a.clicks||0));
   637|    const hotIds = new Set();
   638|    for (let i = 0; i < Math.min(2, byClicks.length); i++) {
   639|        if ((byClicks[i].clicks||0) > 0) hotIds.add(byClicks[i].id);
   640|    }
   641|
   642|    sorted.forEach(aff => {
   643|        const isHot = hotIds.has(aff.id);
   644|        const features = normalizeTags(aff.features || aff.tags);
   645|        const maxTags = 4;
   646|        const visibleTags = features.slice(0, maxTags);
   647|        const hiddenTags = features.slice(maxTags);
   648|        const tagsHtml = visibleTags.map(f => 
   649|            `<span class="affiliate-tag" data-tag="${escHtml(f)}" onclick="event.stopPropagation();filterByTag('${escHtml(f)}')">#${escHtml(f)}</span>`
   650|        ).join('');
   651|        const moreBtn = hiddenTags.length > 0 
   652|            ? `<span class="tag-more" onclick="event.stopPropagation();toggleHiddenTags(this, '${aff.id}')">+${hiddenTags.length} lisää...</span>`
   653|            : '';
   654|        const hiddenTagsHtml = hiddenTags.map(f => 
   655|            `<span class="affiliate-tag hidden-tags" data-tag="${escHtml(f)}" data-aff="${aff.id}" onclick="event.stopPropagation();filterByTag('${escHtml(f)}')">#${escHtml(f)}</span>`
   656|        ).join('');
   657|        
   658|        const card = document.createElement('div');
   659|        card.className = 'affiliate-card compact' + (isHot ? ' hot' : '');
   660|        // Color is set as CSS custom prop but NOT applied visually except on hover
   661|        if (aff.color) card.style.setProperty('--link-accent', aff.color);
   662|        card.dataset.tags = JSON.stringify(features);
   663|        card.dataset.id = aff.id;
   664|        card.innerHTML = `
   665|            ${isHot ? '<div class="hot-badge">🔥 HOT</div>' : ''}
   666|            ${aff.image ? `
   667|            <div class="affiliate-image-wrap">
   668|                <img src="${escHtml(aff.image)}" alt="${escHtml(aff.title)}" class="affiliate-image" loading="lazy">
   669|                ${aff.youtubeId ? `<div class="yt-play-overlay" onclick="event.stopPropagation();showYtEmbed('${escHtml(aff.youtubeId)}')"><span>▶</span></div>` : ''}
   670|            </div>
   671|            ` : ''}
   672|            <div class="affiliate-content">
   673|                <div class="affiliate-title">${escHtml(aff.title)}</div>
   674|                <div class="affiliate-desc">${escHtml(aff.description || '')}</div>
   675|                <div class="affiliate-price">${escHtml(aff.price || '')}</div>
   676|                <div class="affiliate-features">${tagsHtml}${moreBtn}${hiddenTagsHtml}</div>
   677|                ${aff.youtubeId ? `<button class="yt-preview-btn" onclick="event.stopPropagation();showYtEmbed('${escHtml(aff.youtubeId)}')"><i data-lucide="play"></i> Katso video</button>` : ''}
   678|                <a href="${escHtml(aff.url)}" target="_blank" rel="noopener noreferrer" class="affiliate-cta" onclick="event.stopPropagation();trackClick('affiliates','${aff.id}')">
   679|                    <i data-lucide="shopping-cart"></i> Osta nyt
   680|                </a>
   681|                <div class="affiliate-clicks">${(aff.clicks||0)} clicks</div>
   682|            </div>
   683|        `;
   684|        
   685|        card.addEventListener('click', (e) => {
   686|            if (e.target.closest('.affiliate-cta') || e.target.closest('.affiliate-tag') || e.target.closest('.yt-preview-btn') || e.target.closest('.yt-play-overlay')) return;
   687|            showItemPopup({...aff, isHot}, 'affiliate');
   688|        });
   689|        container.appendChild(card);
   690|    });
   691|    
   692|    filterShop();
   693|}
   694|
   695|function normalizeTags(raw) {
   696|    if (Array.isArray(raw)) return raw.map(t => String(t).trim().toLowerCase()).filter(Boolean);
   697|    if (typeof raw === 'string') return raw.split(',').map(t => t.trim().toLowerCase()).filter(Boolean);
   698|    return [];
   699|}
