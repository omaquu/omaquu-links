   750|
   751|function filterShop() {
   752|    const searchVal = document.getElementById('shopSearch')?.value.toLowerCase() || '';
   753|    const cards = document.querySelectorAll('.affiliate-card');
   754|    let visibleCount = 0;
   755|    
   756|    cards.forEach(card => {
   757|        const tags = JSON.parse(card.dataset.tags || '[]');
   758|        const text = card.textContent.toLowerCase();
   759|        
   760|        const matchesSearch = !searchVal || text.includes(searchVal);
   761|        const matchesFilters = activeFilters.size === 0 || 
   762|            Array.from(activeFilters).every(f => tags.includes(f));
   763|        
   764|        if (matchesSearch && matchesFilters) {
   765|            card.classList.remove('hidden-card', 'faded', 'highlighted');
   766|            if (searchVal || activeFilters.size > 0) card.classList.add('highlighted');
   767|            visibleCount++;
   768|        } else {
   769|            card.classList.add('hidden-card');
   770|            card.classList.remove('highlighted');
   771|        }
   772|    });
   773|    
   774|    const noResults = document.getElementById('noResults');
   775|    if (noResults) noResults.style.display = visibleCount === 0 ? 'block' : 'none';
   776|}
   777|
   778|// ─── STREAM EMBED (Kick/Twitch) ─────────────────────────────────────────
   779|async function checkStreamLive() {
   780|    const embed = document.getElementById('kickEmbed');
   781|    const frame = document.getElementById('kickFrame');
   782|    const liveDot = document.getElementById('liveDot');
   783|    const embedTitle = document.getElementById('embedTitle');
   784|    
   785|    const alwaysShow = siteData.streamAlwaysVisible === true;
   786|    const streamType = siteData.streamType || 'kick';
   787|    const streamUser = siteData.streamUsername || 'omaquu';
   788|    
   789|    // Set embed src based on type
   790|    let embedSrc = '';
   791|    if (streamType === 'twitch') {
   792|        embedSrc = `https://player.twitch.tv/?channel=${streamUser}&parent=${location.hostname}`;
   793|    } else {
   794|        embedSrc = `https://player.kick.com/${streamUser}`;
   795|    }
   796|    
   797|    frame.src = embedSrc;
   798|    
   799|    // Try to check live status
   800|    let isLive = false;
   801|    try {
   802|        if (streamType === 'kick') {
   803|            const res = await fetch(`https://kick.com/api/v2/channels/${streamUser}`);
   804|            if (res.ok) {
   805|                const data = await res.json();
   806|                if (data.data?.livestream) isLive = true;
   807|            }
   808|        }
   809|        // Twitch live check would need client-id — skip for now
   810|        if (streamType === 'twitch') isLive = true;  // Twitch needs auth, assume live when always
   811|    } catch(e) {}
   812|    
   813|    if (isLive) {
   814|        embed.style.display = 'block';
   815|        liveDot.style.background = 'var(--live)';
   816|        liveDot.classList.add('live-dot');
   817|        embedTitle.textContent = `LIVE @${streamUser}`;
   818|        embed.style.borderColor = 'var(--live)';
   819|        embed.style.boxShadow = '0 0 20px rgba(239,68,68,0.2)';
   820|    } else if (alwaysShow) {
   821|        embed.style.display = 'block';
   822|        liveDot.style.background = 'var(--text-muted)';
   823|        liveDot.classList.remove('live-dot');
   824|        embedTitle.textContent = `@${streamUser} · Offline · ${streamType.toUpperCase()}`;
   825|        embed.style.borderColor = 'var(--border)';
   826|        embed.style.boxShadow = 'none';
   827|    } else {
   828|        embed.style.display = 'none';
   829|    }
   830|}
